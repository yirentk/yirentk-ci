apiVersion: apps/v1
kind: Deployment
metadata:
  name: yirentk
  namespace: yirentk
spec:
  replicas: 1
  revisionHistoryLimit: 3
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: yirentk
  template:
    metadata:
      labels:
        app: yirentk
    spec:
      containers:
        - name: yirentk
          image: __IMAGE__
          imagePullPolicy: Never
          ports:
            - name: http
              containerPort: 8080
              hostPort: __HOST_PORT__
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /app/config.toml
              subPath: config.toml
            - name: data
              mountPath: /app/data
          readinessProbe:
            httpGet:
              path: /api/healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 6
          livenessProbe:
            httpGet:
              path: /api/healthz
              port: http
            initialDelaySeconds: 60
            periodSeconds: 20
            timeoutSeconds: 5
            failureThreshold: 3
          resources:
            requests:
              cpu: 200m
              memory: 256Mi
            limits:
              cpu: "1"
              memory: 1Gi
      volumes:
        - name: config
          secret:
            secretName: yirentk-config
        - name: data
          persistentVolumeClaim:
            claimName: yirentk-data
