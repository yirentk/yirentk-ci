[api]
addr = ":8080"
data_dir = "/app/data"
static_dir = "/app/web/dist"
allowed_origin = "http://__SERVER_HOST__:__HOST_PORT__"

[database]
driver = "postgres"
dsn = "__DATABASE_DSN__"
max_open_conns = 20
max_idle_conns = 10
conn_max_lifetime = "30m"
conn_max_idle_time = "5m"

[auth]
issuer = "yirentk"
secret = "__AUTH_SECRET__"
access_token_ttl = "15m"
refresh_token_ttl = "168h"
refresh_cookie_name = "yirentk_session"

[greetings]
bind_code_ttl = "24h"

[knowledge]
output_dir = "/app/output"
reindex_mode = "incremental"
max_chunk_chars = 520
lexical_top_k = 20
vector_top_k = 20
retrieval_top_k = 8
auto_rebuild = false

[model]
provider = "openai-compatible"
base_url = "__MODEL_BASE_URL__"
api_key = "__MODEL_API_KEY__"
chat_model = "gpt-5.4-mini"
embedding_model = "local"
vector_dimensions = 128
max_context_chunks = 6
grounding_threshold = 0.015
